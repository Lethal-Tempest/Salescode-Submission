    <!-- Main Logic -->
    <script>
        const video = document.getElementById('webcam');
        const canvas = document.getElementById('canvas');
        const videoContainer = document.getElementById('video-container');
        const cameraPlaceholder = document.getElementById('camera-placeholder');
        const scannerLine = document.getElementById('scanner-line');
        const toggleScanBtn = document.getElementById('toggle-scan-btn');
        const snapshotBtn = document.getElementById('snapshot-btn');
        const meterFill = document.getElementById('meter-fill');
        const probabilityVal = document.getElementById('probability-val');
        const verdictBanner = document.getElementById('verdict-banner');
        const verdictIcon = document.getElementById('verdict-icon');
        const verdictTitle = document.getElementById('verdict-title');
        const verdictDesc = document.getElementById('verdict-desc');
        const latencyVal = document.getElementById('latency-val');

        let isScanning = false;
        let scanInterval = null;
        let stream = null;

        // Path of progress ring
        const circumference = 2 * Math.PI * 42; // 263.89

        async function startCamera() {
            try {
                stream = await navigator.mediaDevices.getUserMedia({
                    video: {
                        width: { ideal: 1280 },
                        height: { ideal: 720 },
                        facingMode: 'user'
                    }
                });
                video.srcObject = stream;
                
                // Update UI state
                cameraPlaceholder.classList.add('hidden');
                toggleScanBtn.disabled = false;
                toggleScanBtn.classList.remove('bg-blue-600/50', 'cursor-not-allowed');
                toggleScanBtn.classList.add('hover:bg-blue-500', 'active:bg-blue-700');
                snapshotBtn.disabled = false;
            } catch (err) {
                console.error("Camera access failed:", err);
                alert("Could not access webcam. Please check permissions.");
            }
        }

        function toggleScanning() {
            if (isScanning) {
                stopScanning();
            } else {
                startScanning();
            }
        }

        function startScanning() {
            isScanning = true;
            toggleScanBtn.innerText = "Stop Real-time Scan";
            toggleScanBtn.classList.remove('bg-blue-600', 'hover:bg-blue-500');
            toggleScanBtn.classList.add('bg-red-600', 'hover:bg-red-500');
            scannerLine.classList.remove('hidden');
            
            // Periodically check frame
            scanInterval = setInterval(captureFrame, 1500); 
            captureFrame(); // trigger immediately
        }

        function stopScanning() {
            isScanning = false;
            toggleScanBtn.innerText = "Start Real-time Scan";
            toggleScanBtn.classList.remove('bg-red-600', 'hover:bg-red-500');
            toggleScanBtn.classList.add('bg-blue-600', 'hover:bg-blue-500');
            scannerLine.classList.add('hidden');
            
            clearInterval(scanInterval);
        }

        function updateResultMeter(prob, latency) {
            const percentage = Math.round(prob * 100);
            probabilityVal.innerText = `${percentage}%`;
            
            // Calculate progress offset
            const offset = circumference - (prob * circumference);
            meterFill.style.strokeDashoffset = offset;
            
            if (latency !== undefined) {
                latencyVal.innerText = `Latency: ${latency} ms`;
                latencyVal.classList.remove('hidden');
            }

            // Update UI based on class
            if (prob >= 0.5) {
                // SCREEN RECAPTURE (FRAUD)
                videoContainer.className = "relative glass rounded-2xl overflow-hidden border p-2 shadow-2xl transition-all duration-300 neon-glow-fake";
                meterFill.style.stroke = "#ef4444";
                
                verdictBanner.className = "w-full bg-red-950/20 border border-red-800/40 rounded-xl p-4 flex items-center justify-between text-center transition-all duration-300";
                verdictIcon.className = "w-8 h-8 rounded-full bg-red-900/40 flex items-center justify-center";
                verdictIcon.innerHTML = `<svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>`;
                
                verdictTitle.className = "text-sm font-bold text-red-400";
                verdictTitle.innerText = "Recapture / Fake Photo";
                verdictDesc.innerText = "This image appears to show a photo of a screen.";
            } else {
                // REAL PHOTO
                videoContainer.className = "relative glass rounded-2xl overflow-hidden border p-2 shadow-2xl transition-all duration-300 neon-glow-real";
                meterFill.style.stroke = "#22c55e";
                
                verdictBanner.className = "w-full bg-emerald-950/20 border border-emerald-800/40 rounded-xl p-4 flex items-center justify-between text-center transition-all duration-300";
                verdictIcon.className = "w-8 h-8 rounded-full bg-emerald-900/40 flex items-center justify-center";
                verdictIcon.innerHTML = `<svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>`;
                
                verdictTitle.className = "text-sm font-bold text-emerald-400";
                verdictTitle.innerText = "Genuine Real Photo";
                verdictDesc.innerText = "This image appears to be a direct photo of real objects.";
            }
        }

        function captureFrame() {
            const ctx = canvas.getContext('2d');
            
            // Draw current webcam frame to canvas
            ctx.save();
            ctx.translate(canvas.width, 0);
            ctx.scale(-1, 1); // Flip horizontally to match mirror preview
            ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
            ctx.restore();
            
            // Get base64 string from canvas
            const dataUrl = canvas.toDataURL('image/jpeg', 0.8);
            
            // Send to server
            const startTime = performance.now();
            
            fetch('/predict', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ image: dataUrl, model_type: 'resnet101' })
            })
            .then(res => res.json())
            .then(data => {
                const endTime = performance.now();
                const latency = Math.round(endTime - startTime);
                
                if (data.probability !== undefined) {
                    updateResultMeter(data.probability, latency);
                    if (data.device) {
                        document.getElementById('device-val').innerText = data.device;
                    }
                } else {
                    console.error("Prediction error:", data.error);
                }
            })
            .catch(err => {
                console.error("Fetch error:", err);
            });
        }
    </script>
</body>
